<ui:FluentWindow x:Class="WinUserLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:WinUserLauncher"
        xmlns:models="clr-namespace:WinUserLauncher.Models"
        mc:Ignorable="d"
        Title="Windows系统应用启动器" 
        Height="700" 
        Width="1100"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    
    <Grid>
        <!-- 顶部标题栏区域 -->
        <ui:TitleBar 
            Title="Windows系统应用启动器"
            Icon="{ui:SymbolIcon Apps24}"
            VerticalAlignment="Top"
            Margin="0,0,0,0"/>

        <!-- 主内容区域（标题栏下方） -->
        <Grid Margin="0,32,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧导航栏 -->
            <ui:NavigationView 
                Grid.Column="0"
                x:Name="SideNavigationView"
                OpenPaneLength="240"
                CompactPaneLength="48"
                PaneDisplayMode="Left"
                IsPaneOpen="True"
                IsPaneToggleVisible="True"
                IsBackButtonVisible="Collapsed"
                Margin="0,0,0,0">
                
                <!-- 导航菜单项 -->
                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem 
                        Content="常用快捷"
                        Tag="QuickAccess"
                        Icon="{ui:SymbolIcon Star24}"
                        Click="OnCategoryClick"/>

                    <ui:NavigationViewItem 
                        Content="系统工具"
                        Tag="SystemTools"
                        Icon="{ui:SymbolIcon Toolbox24}"
                        Click="OnCategoryClick"/>

                    <ui:NavigationViewItem 
                        Content="系统设置"
                        Tag="Settings"
                        Icon="{ui:SymbolIcon Settings24}"
                        Click="OnCategoryClick"/>

                    <ui:NavigationViewItem 
                        Content="娱乐休闲"
                        Tag="Entertainment"
                        Icon="{ui:SymbolIcon Games24}"
                        Click="OnCategoryClick"/>

                    <ui:NavigationViewItem 
                        Content="办公效率"
                        Tag="Productivity"
                        Icon="{ui:SymbolIcon Checkmark24}"
                        Click="OnCategoryClick"/>

                    <ui:NavigationViewItem 
                        Content="网络应用"
                        Tag="Network"
                        Icon="{ui:SymbolIcon Globe24}"
                        Click="OnCategoryClick"/>

                    <ui:NavigationViewItem 
                        Content="安全工具"
                        Tag="Security"
                        Icon="{ui:SymbolIcon Shield24}"
                        Click="OnCategoryClick"/>

                    <ui:NavigationViewItem 
                        Content="其他工具"
                        Tag="Other"
                        Icon="{ui:SymbolIcon MoreHorizontal24}"
                        Click="OnCategoryClick"/>
                </ui:NavigationView.MenuItems>

                <!-- 页脚菜单项 -->
                <ui:NavigationView.FooterMenuItems>
                    <ui:NavigationViewItem 
                        Content="显示全部"
                        Tag="ShowAll"
                        Icon="{ui:SymbolIcon Apps24}"
                        Click="OnShowAllClick"/>
                </ui:NavigationView.FooterMenuItems>
            </ui:NavigationView>

            <!-- 右侧内容区域 -->
            <ui:Card Grid.Column="1" Margin="0,0,24,24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 搜索框 -->
                    <ui:AutoSuggestBox 
                        Grid.Row="0"
                        x:Name="SearchBox"
                        PlaceholderText="搜索应用..."
                        Margin="16,16,16,12"
                        TextChanged="OnSearchTextChanged"/>

                    <!-- 应用网格 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="AppsGrid" ItemsSource="{Binding SystemApps}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="models:SystemApp">
                                    <ui:Card 
                                        Margin="8"
                                        Width="200"
                                        Height="140"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="OnAppClick"
                                        Tag="{Binding}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- 图标 -->
                                            <ui:SymbolIcon 
                                                Grid.Row="0"
                                                x:Name="AppIcon"
                                                Symbol="Apps24"
                                                FontSize="32"
                                                HorizontalAlignment="Center"
                                                Margin="0,12,0,8"
                                                Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"/>

                                            <!-- 名称 -->
                                            <TextBlock 
                                                Grid.Row="1"
                                                Text="{Binding Name}"
                                                TextAlignment="Center"
                                                TextWrapping="Wrap"
                                                FontWeight="SemiBold"
                                                FontSize="14"
                                                Margin="8,0,8,4"
                                                VerticalAlignment="Center"/>

                                            <!-- 描述 -->
                                            <TextBlock 
                                                Grid.Row="2"
                                                Text="{Binding Description}"
                                                TextAlignment="Center"
                                                TextWrapping="Wrap"
                                                FontSize="11"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                Margin="8,0,8,12"
                                                MaxHeight="40"
                                                TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </ui:Card>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </ui:Card>
        </Grid>
    </Grid>
</ui:FluentWindow>